# Gemini API (required for LLM re-ranking). Get key: https://ai.google.dev/gemini-api/docs
GEMINI_API_KEY=your_api_key_here

# Optional: primary model (default: gemini-2.0-flash). Fallbacks tried on 429.
# GEMINI_MODEL=gemini-2.0-flash

# Optional: path for LLM request/response logs
# LLM_LOG_PATH=data/llm.log
